{
  "manifest_version": 2,
  "name": "Copy DOM innerText",
  "version": "1.0",
  "description": "Copy the rendered innerText of a selected DOM node from the Inspector sidebar",
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "devtools_page": "devtools-page.html",
  "permissions": [
    "clipboardWrite",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "copy-innertext@example.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
